# Position
anchor=top-right

# Size
width=350
height=120
margin=10
padding=12
border-size=2
border-radius=10

# Fonts
font=FiraMono Nerd Font 11

# Colors
background-color=#1e1e2eee
text-color=#cdd6f4ff
border-color=#A7C080

# Progress bars
progress-color=over #313244ff

# Behavior
default-timeout=5000
ignore-timeout=0

# Icons
icons=1
max-icon-size=48

# Group similar notifications
group-by=app-name

# Markup support
markup=1

# Actions
actions=1

# Mouse bindings
on-button-left=invoke-default-action
on-button-right=dismiss

# Notification Urgency
[urgency=normal]
border-color=#D3C6AA

[urgency=critical]
border-color=#E67E80
default-timeout=0
